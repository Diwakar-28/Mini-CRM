# Server port configurations
PORT=5000

# Channel Delivery Simulator port (defaults to 5001)
CHANNEL_SERVICE_URL=http://localhost:5001

# AI agent configuration (optional, if none is supplied, CRM runs in mock rule-parsing mode)
GEMINI_API_KEY=
