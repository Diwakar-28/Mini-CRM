{
  "name": "xeno-crm-root",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "channel-service",
    "frontend"
  ],
  "scripts": {
    "dev:backend": "npm run dev -w backend",
    "dev:frontend": "npm run dev -w frontend",
    "dev:channel": "npm run dev -w channel-service",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:channel\" \"npm run dev:frontend\"",
    "build": "npm run build -w shared && npm run build --workspaces",
    "db:migrate": "npm run db:migrate -w backend",
    "db:seed": "npm run db:seed -w backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
